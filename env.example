# Real Estate Intelligence API Environment Variables
# Copy this file to .env and fill in your actual values

# Census API Key (get free key at: https://api.census.gov/data/key_signup.html)
# REQUIRED: You must set this value
CENSUS_API_KEY=your_census_api_key_here

# RapidAPI Configuration
# OPTIONAL: Default value shown below
RAPIDAPI_HOST=real-estate-intelligence-api.p.rapidapi.com

# Database Configuration
# OPTIONAL: Default value shown below
DATABASE_PATH=real_estate_intelligence.db

# Flask Configuration
# OPTIONAL: Default values shown below
FLASK_ENV=production
FLASK_DEBUG=False

# Vercel Configuration (for deployment)
# OPTIONAL: Only needed for GitHub Actions deployment
VERCEL_TOKEN=your_vercel_token_here
VERCEL_ORG_ID=your_vercel_org_id_here
VERCEL_PROJECT_ID=your_vercel_project_id_here 